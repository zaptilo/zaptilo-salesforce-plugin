<?xml version="1.0" encoding="UTF-8"?>
<PermissionSet xmlns="http://soap.sforce.com/2006/04/metadata">
    <description>Grants permission to send WhatsApp messages via Zaptilo and to read message logs. Does NOT grant Settings access — assign Zaptilo_Admin for that.</description>
    <hasActivationRequired>false</hasActivationRequired>
    <label>Zaptilo User</label>
    <license>Salesforce</license>

    <applicationVisibilities>
        <application>Zaptilo</application>
        <visible>true</visible>
    </applicationVisibilities>

    <classAccesses>
        <apexClass>ZaptiloAPI</apexClass>
        <enabled>true</enabled>
    </classAccesses>
    <classAccesses>
        <apexClass>ZaptiloSendController</apexClass>
        <enabled>true</enabled>
    </classAccesses>

    <objectPermissions>
        <object>WhatsApp_Message__c</object>
        <allowCreate>true</allowCreate>
        <allowDelete>false</allowDelete>
        <allowEdit>true</allowEdit>
        <allowRead>true</allowRead>
        <modifyAllRecords>false</modifyAllRecords>
        <viewAllRecords>false</viewAllRecords>
    </objectPermissions>

    <fieldPermissions>
        <editable>true</editable>
        <field>WhatsApp_Message__c.Contact__c</field>
        <readable>true</readable>
    </fieldPermissions>
    <fieldPermissions>
        <editable>true</editable>
        <field>WhatsApp_Message__c.Lead__c</field>
        <readable>true</readable>
    </fieldPermissions>
    <fieldPermissions>
        <editable>true</editable>
        <field>WhatsApp_Message__c.Body__c</field>
        <readable>true</readable>
    </fieldPermissions>
    <fieldPermissions>
        <editable>true</editable>
        <field>WhatsApp_Message__c.Template_Name__c</field>
        <readable>true</readable>
    </fieldPermissions>
    <fieldPermissions>
        <editable>true</editable>
        <field>WhatsApp_Message__c.Status__c</field>
        <readable>true</readable>
    </fieldPermissions>
    <fieldPermissions>
        <editable>true</editable>
        <field>WhatsApp_Message__c.External_Id__c</field>
        <readable>true</readable>
    </fieldPermissions>

    <fieldPermissions>
        <editable>true</editable>
        <field>Contact.Do_Not_WhatsApp__c</field>
        <readable>true</readable>
    </fieldPermissions>
    <fieldPermissions>
        <editable>true</editable>
        <field>Lead.Do_Not_WhatsApp__c</field>
        <readable>true</readable>
    </fieldPermissions>

    <tabSettings>
        <tab>Zaptilo_Settings</tab>
        <visibility>None</visibility>
    </tabSettings>
</PermissionSet>
